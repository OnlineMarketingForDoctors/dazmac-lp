{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/usa", "destination": "/car-import-usa", "permanent": true },
    { "source": "/usa.html", "destination": "/car-import-usa", "permanent": true },
    { "source": "/japan", "destination": "/car-import-japan", "permanent": true },
    { "source": "/japan.html", "destination": "/car-import-japan", "permanent": true },
    { "source": "/nz", "destination": "/car-import-nz", "permanent": true },
    { "source": "/nz.html", "destination": "/car-import-nz", "permanent": true },
    { "source": "/uk", "destination": "/car-import-uk", "permanent": true },
    { "source": "/uk.html", "destination": "/car-import-uk", "permanent": true },
    { "source": "/singapore", "destination": "/car-import-singapore", "permanent": true },
    { "source": "/singapore.html", "destination": "/car-import-singapore", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/landing-page/index.html" },
    { "source": "/car-import", "destination": "/landing-page/car-import.html" },
    { "source": "/car-import.html", "destination": "/landing-page/car-import.html" },
    { "source": "/car-import-usa", "destination": "/landing-page/car-import-usa.html" },
    { "source": "/car-import-usa.html", "destination": "/landing-page/car-import-usa.html" },
    { "source": "/car-import-japan", "destination": "/landing-page/car-import-japan.html" },
    { "source": "/car-import-japan.html", "destination": "/landing-page/car-import-japan.html" },
    { "source": "/car-import-nz", "destination": "/landing-page/car-import-nz.html" },
    { "source": "/car-import-nz.html", "destination": "/landing-page/car-import-nz.html" },
    { "source": "/car-import-uk", "destination": "/landing-page/car-import-uk.html" },
    { "source": "/car-import-uk.html", "destination": "/landing-page/car-import-uk.html" },
    { "source": "/car-import-singapore", "destination": "/landing-page/car-import-singapore.html" },
    { "source": "/car-import-singapore.html", "destination": "/landing-page/car-import-singapore.html" },
    { "source": "/boats", "destination": "/landing-page/boats.html" },
    { "source": "/boats.html", "destination": "/landing-page/boats.html" },
    { "source": "/boats-usa", "destination": "/landing-page/boats-usa.html" },
    { "source": "/boats-usa.html", "destination": "/landing-page/boats-usa.html" },
    { "source": "/boats-nz", "destination": "/landing-page/boats-nz.html" },
    { "source": "/boats-nz.html", "destination": "/landing-page/boats-nz.html" },
    { "source": "/exports", "destination": "/landing-page/exports.html" },
    { "source": "/exports.html", "destination": "/landing-page/exports.html" },
    { "source": "/insurance", "destination": "/landing-page/insurance.html" },
    { "source": "/insurance.html", "destination": "/landing-page/insurance.html" },
    { "source": "/styles.css", "destination": "/landing-page/styles.css" },
    { "source": "/boats.css", "destination": "/landing-page/boats.css" },
    { "source": "/exports.css", "destination": "/landing-page/exports.css" },
    { "source": "/insurance.css", "destination": "/landing-page/insurance.css" },
    { "source": "/usa.css", "destination": "/landing-page/usa.css" },
    { "source": "/japan.css", "destination": "/landing-page/japan.css" },
    { "source": "/nz.css", "destination": "/landing-page/nz.css" },
    { "source": "/uk.css", "destination": "/landing-page/uk.css" },
    { "source": "/singapore.css", "destination": "/landing-page/singapore.css" },
    { "source": "/images/:file", "destination": "/landing-page/images/:file" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/landing-page/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
